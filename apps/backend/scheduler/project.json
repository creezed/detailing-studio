{
  "name": "scheduler",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/backend/scheduler/src",
  "projectType": "application",
  "tags": [
    "scope:platform",
    "type:app",
    "platform:node"
  ],
  "targets": {
    "serve": {
      "executor": "@nx/js:node",
      "defaultConfiguration": "development",
      "dependsOn": ["build"],
      "options": {
        "buildTarget": "scheduler:build",
        "runBuildTargetDependencies": false
      },
      "configurations": {
        "development": {
          "buildTarget": "scheduler:build:development"
        },
        "production": {
          "buildTarget": "scheduler:build:production"
        }
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "options": {
        "lintFilePatterns": [
          "apps/backend/scheduler/**/*.ts"
        ]
      }
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/apps/backend/scheduler"],
      "options": {
        "jestConfig": "apps/backend/scheduler/jest.config.ts",
        "passWithNoTests": true
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsc -b apps/backend/scheduler/tsconfig.json --pretty false"
      }
    }
  }
}
