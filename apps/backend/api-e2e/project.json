{
  "name": "backend-api-e2e",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/backend/api-e2e/src",
  "projectType": "application",
  "tags": ["scope:api", "type:e2e", "platform:node"],
  "targets": {
    "e2e": {
      "executor": "@nx/jest:jest",
      "dependsOn": ["api:build"],
      "outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
      "options": {
        "jestConfig": "apps/backend/api-e2e/jest.config.ts",
        "passWithNoTests": false,
        "runInBand": true
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "options": {
        "lintFilePatterns": ["apps/backend/api-e2e/src/**/*.ts"]
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsc -p apps/backend/api-e2e/tsconfig.json --noEmit",
        "cwd": "."
      }
    }
  }
}
