{
  "name": "catalog-application",
  "$schema": "../../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/backend/catalog/application/src",
  "projectType": "library",
  "tags": [
    "scope:catalog",
    "type:application",
    "platform:node"
  ],
  "implicitDependencies": [
    "catalog-domain"
  ],
  "targets": {
    "lint": {
      "executor": "@nx/eslint:lint",
      "options": {
        "lintFilePatterns": [
          "libs/backend/catalog/application/**/*.ts"
        ]
      }
    },
    "test": {
      "executor": "@nx/jest:jest",
      "options": {
        "jestConfig": "libs/backend/catalog/application/jest.config.ts",
        "passWithNoTests": false
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsc -b libs/backend/catalog/application/tsconfig.json --pretty false",
        "cwd": "."
      }
    }
  }
}
