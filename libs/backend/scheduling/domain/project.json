{
  "name": "backend-scheduling-domain",
  "$schema": "../../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/backend/scheduling/domain/src",
  "projectType": "library",
  "tags": ["scope:scheduling", "type:domain", "platform:node"],
  "targets": {
    "lint": {
      "executor": "@nx/eslint:lint",
      "options": {
        "lintFilePatterns": ["libs/backend/scheduling/domain/**/*.ts"]
      }
    },
    "test": {
      "executor": "@nx/jest:jest",
      "options": {
        "jestConfig": "libs/backend/scheduling/domain/jest.config.ts",
        "passWithNoTests": true
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsc -b libs/backend/scheduling/domain/tsconfig.json --pretty false",
        "cwd": "."
      }
    }
  }
}
