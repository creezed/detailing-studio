{
  "name": "iam-infrastructure",
  "$schema": "../../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/backend/iam/infrastructure/src",
  "projectType": "library",
  "tags": [
    "scope:iam",
    "type:infrastructure",
    "platform:node"
  ],
  "targets": {
    "lint": {
      "executor": "@nx/eslint:lint",
      "options": {
        "lintFilePatterns": [
          "libs/backend/iam/infrastructure/**/*.ts"
        ]
      }
    },
    "test": {
      "executor": "@nx/jest:jest",
      "options": {
        "jestConfig": "libs/backend/iam/infrastructure/jest.config.ts",
        "passWithNoTests": false
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsc -b libs/backend/iam/infrastructure/tsconfig.json --pretty false",
        "cwd": "."
      }
    }
  }
}
