{
  "name": "backend-crm-infrastructure",
  "$schema": "../../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/backend/crm/infrastructure/src",
  "projectType": "library",
  "tags": ["scope:crm", "type:infrastructure", "platform:node"],
  "targets": {
    "lint": {
      "executor": "@nx/eslint:lint",
      "options": {
        "lintFilePatterns": ["libs/backend/crm/infrastructure/**/*.ts"]
      }
    },
    "test": {
      "executor": "@nx/jest:jest",
      "options": {
        "jestConfig": "libs/backend/crm/infrastructure/jest.config.ts",
        "passWithNoTests": true
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsc -b libs/backend/crm/infrastructure/tsconfig.json --pretty false",
        "cwd": "."
      }
    }
  }
}
