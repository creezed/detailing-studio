# Database
# Имя основной dev-базы PostgreSQL.
DEFAULT_DB=detailing
# Пользователь PostgreSQL для локальной разработки.
POSTGRES_USER=detailing
# Пароль PostgreSQL для локальной разработки; замените перед запуском.
POSTGRES_PASSWORD=<change-me>
# Локальный порт PostgreSQL, привязанный только к 127.0.0.1.
POSTGRES_PORT=5432
# Connection string для backend API в локальной разработке.
DATABASE_URL=postgres://detailing:<change-me>@127.0.0.1:5432/detailing
# Имя test-базы PostgreSQL для integration/CI.
TEST_DEFAULT_DB=detailing_test
# Пользователь PostgreSQL для integration/CI.
TEST_POSTGRES_USER=detailing_test
# Пароль PostgreSQL для integration/CI; задаётся в CI secret/local env.
TEST_POSTGRES_PASSWORD=<change-me>
# Локальный порт test PostgreSQL, привязанный только к 127.0.0.1.
TEST_POSTGRES_PORT=15432
# Connection string для integration-тестов.
TEST_DATABASE_URL=postgres://detailing_test:<change-me>@127.0.0.1:15432/detailing_test

# Redis
# Пароль Redis для локальной разработки; замените перед запуском.
REDIS_PASSWORD=<change-me>
# Локальный порт Redis, привязанный только к 127.0.0.1.
REDIS_PORT=6379
# Redis URL для backend API в локальной разработке.
REDIS_URL=redis://:<change-me>@127.0.0.1:6379
# Пароль Redis для integration/CI; задаётся в CI secret/local env.
TEST_REDIS_PASSWORD=<change-me>
# Локальный порт test Redis, привязанный только к 127.0.0.1.
TEST_REDIS_PORT=16379
# Redis URL для integration-тестов.
TEST_REDIS_URL=redis://:<change-me>@127.0.0.1:16379

# MinIO
# Root user MinIO для локальной разработки.
MINIO_ROOT_USER=minio
# Root password MinIO; замените перед запуском.
MINIO_ROOT_PASSWORD=<change-me>
# Bucket для фотографий.
MINIO_BUCKET=photos
# Локальный порт S3 API MinIO, привязанный только к 127.0.0.1.
MINIO_API_PORT=9000
# Локальный порт консоли MinIO, привязанный только к 127.0.0.1.
MINIO_CONSOLE_PORT=9001
# Endpoint S3 API для backend API в локальной разработке.
MINIO_ENDPOINT=http://127.0.0.1:9000
# Access key для S3 adapter; в dev совпадает с MINIO_ROOT_USER.
MINIO_ACCESS_KEY=minio
# Secret key для S3 adapter; в dev совпадает с MINIO_ROOT_PASSWORD.
MINIO_SECRET_KEY=<change-me>

# Auth
# JWT secret; сгенерируйте локально, например openssl rand -base64 32.
JWT_SECRET=<generate-random-secret>
# Время жизни access token.
JWT_ACCESS_TTL=15m
# Время жизни refresh token.
JWT_REFRESH_TTL=30d
# Public VAPID key для push-уведомлений.
VAPID_PUBLIC_KEY=<generate-vapid-public-key>
# Private VAPID key для push-уведомлений.
VAPID_PRIVATE_KEY=<generate-vapid-private-key>

# SMS
# API key SMS.ru; пусто отключает реальную отправку в dev.
SMS_RU_API_KEY=<sms-ru-api-key>
# Имя отправителя SMS, если провайдер поддерживает sender id.
SMS_SENDER=Detailing

# OAuth
# OAuth client id для Yandex ID.
YANDEX_ID_CLIENT_ID=<yandex-client-id>
# OAuth client secret для Yandex ID.
YANDEX_ID_CLIENT_SECRET=<yandex-client-secret>
# Redirect URI для локального OAuth callback.
YANDEX_ID_REDIRECT_URI=http://localhost:3000/api/v1/auth/yandex/callback

# Telegram
# Bot token Telegram; пусто отключает Telegram-интеграцию в dev.
TELEGRAM_BOT_TOKEN=<telegram-bot-token>
# Имя Telegram bot без @.
TELEGRAM_BOT_NAME=<telegram-bot-name>

# App
# Публичный host для CORS, OAuth callback и ссылок в уведомлениях.
PUBLIC_HOST=localhost
# Публичный API URL для frontend-приложений.
PUBLIC_API_URL=http://localhost:3000/api/v1
# Port backend API.
API_PORT=3000
# Node environment для локальной разработки.
NODE_ENV=development
# SMTP host для dev; MailHog из docker-compose.yml.
SMTP_HOST=127.0.0.1
# SMTP port для dev; MailHog из docker-compose.yml.
SMTP_PORT=1025
# SMTP user; для MailHog оставить пустым.
SMTP_USER=
# SMTP password; для MailHog оставить пустым.
SMTP_PASSWORD=
# MailHog SMTP port, привязанный только к 127.0.0.1.
MAILHOG_SMTP_PORT=1025
# MailHog web UI port, привязанный только к 127.0.0.1.
MAILHOG_UI_PORT=8025
