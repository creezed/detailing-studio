      "@det/backend-crm-interfaces": ["libs/backend/crm/interfaces/src/index.ts"],
      "@det/backend-scheduling-application": [
        "libs/backend/scheduling/application/src/index.ts"
      ],
      "@det/backend-scheduling-domain": ["libs/backend/scheduling/domain/src/index.ts"],
      "@det/backend-scheduling-infrastructure": [
        "libs/backend/scheduling/infrastructure/src/index.ts"
      ],
      "@det/backend-scheduling-interfaces": [
        "libs/backend/scheduling/interfaces/src/index.ts"
      ],
      "@det/backend-inventory-application": ["libs/backend/inventory/application/src/index.ts"],
      "@det/backend-inventory-domain": ["libs/backend/inventory/domain/src/index.ts"],
      "@det/backend-inventory-infrastructure": [
        "libs/backend/inventory/infrastructure/src/index.ts"
      ],
      "@det/backend-inventory-interfaces": ["libs/backend/inventory/interfaces/src/index.ts"],
      "@det/backend-work-order-application": [
        "libs/backend/work-order/application/src/index.ts"
      ],
      "@det/backend-work-order-domain": ["libs/backend/work-order/domain/src/index.ts"],
      "@det/backend-work-order-infrastructure": [
        "libs/backend/work-order/infrastructure/src/index.ts"
      ],
      "@det/backend-work-order-interfaces": [
        "libs/backend/work-order/interfaces/src/index.ts"
      ],
      "@det/backend-iam-application": ["libs/backend/iam/application/src/index.ts"],
      "@det/backend-iam-domain": ["libs/backend/iam/domain/src/index.ts"],
